// Copy this file to "secrets.h" (same folder) and fill in your WiFi for direct
// bring-up. secrets.h is gitignored and never committed.
//
// If WIFI_SSID is left empty, the firmware uses the WiFiManager captive portal
// (SSID "OSOS-Setup"). Holding BOOT at power-on always forces the portal.
#pragma once

#define WIFI_SSID ""   // e.g. "my-2g-network"
#define WIFI_PASS ""

